{
  "name": "Robot Shop Observability",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "forwardPorts": [8080, 3000, 16686, 9090, 9003],
  "portsAttributes": {
    "8080": { "label": "Robot Shop",  "onAutoForward": "notify" },
    "3000": { "label": "Grafana",     "onAutoForward": "notify" },
    "16686": { "label": "Jaeger",      "onAutoForward": "openBrowser" },
    "9090": { "label": "Prometheus",  "onAutoForward": "notify" },
    "9003": { "label": "OpenCost",    "onAutoForward": "notify" }
  }
}